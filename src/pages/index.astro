---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header';
import Footer from '../components/Footer.astro';
import FAQ from '../components/FAQ';

const pathways = [
  {
    title: 'Access',
    eyebrow: 'Get back in',
    copy: 'Open trails, gates, fence rows, and working routes so the property is usable again.',
    image: '/images/netx/homepage/trail-clearing.jpg',
    href: '/services/trail-clearing',
  },
  {
    title: 'Reclaim',
    eyebrow: 'Recover value',
    copy: 'Thin the invasive understory, reveal keeper trees, and turn neglected acreage into ground you can manage.',
    image: '/images/netx/homepage/acreage-cleanup.jpg',
    href: '/services/acreage-cleanup',
  },
  {
    title: 'Prepare',
    eyebrow: 'Set up the next phase',
    copy: 'Create practical openings for homesites, barns, driveways, food plots, utilities, and future improvements.',
    image: '/images/netx/homepage/site-preparation.jpg',
    href: '/services/site-preparation',
  },
];

const planningSteps = [
  ['01', 'Walk the goal', 'We start with what the property needs to become — access, visibility, hunting routes, fence repair, homesite prep, or a cleaner long-term maintenance plan.'],
  ['02', 'Mark what matters', 'Keeper trees, shade, screening, property lines, drainage, access points, and sensitive areas shape the clearing plan.'],
  ['03', 'Clear with restraint', 'Brush and invasive growth come out. Useful structure stays. The result should feel opened up, not stripped bare.'],
  ['04', 'Leave a maintainable finish', 'The job is scoped around what happens after the machine leaves: mowing, fencing, trails, pasture edges, access, and next-phase work.'],
];

const services = [
  { title: 'Forestry Mulching', copy: 'Process brush and saplings in place into a cleaner mulch layer.', href: '/services/forestry-mulching' },
  { title: 'Trail Cutting', copy: 'Open UTV, hunting, equipment, and walking access routes.', href: '/services/trail-clearing' },
  { title: 'Fence Line Clearing', copy: 'Recover gates, corners, easements, and boundary access.', href: '/services/fence-line-clearing' },
  { title: 'Acreage Cleanup', copy: 'Reset overgrown, inherited, neglected, or storm-damaged ground.', href: '/services/acreage-cleanup' },
  { title: 'Homesite Prep', copy: 'Clear usable openings for cabins, shops, barns, driveways, and utilities.', href: '/services/site-preparation' },
  { title: 'Rural Land Clearing', copy: 'Selective clearing for ranches, wooded lots, pasture edges, and rural property work.', href: '/services/land-clearing' },
];

const fieldNotes = [
  {
    title: 'Open the path before you open the whole property.',
    copy: 'A trail-first approach often reveals what actually needs clearing and avoids wasting money on areas that do not matter yet.',
    image: '/images/netx/before-after/trail-clearing.jpg',
  },
  {
    title: 'Preserve the good trees. Remove the pressure.',
    copy: 'The best rural properties keep shade, character, and screening while removing the brush layer that blocks access and visibility.',
    image: '/images/netx/services/forestry-mulching-before-after/acreage-understory.jpg',
  },
  {
    title: 'Plan the finish around maintenance.',
    copy: 'A clean clearing job should make mowing, fencing, hunting access, or construction easier months after the machine leaves.',
    image: '/images/netx/before-after/acreage-cleanup.jpg',
  },
];

const videoNotes = [
  { id: 'zTuaiZSM-Q0', title: 'From Lead to Cleared Land', copy: 'What a professional clearing process looks like from first conversation to finished ground.' },
  { id: 'TUKDq71bvss', title: 'Pricing the Right Way', copy: 'Why a clear scope beats guessing at open-ended hourly machine time.' },
];

const faqItems = [
  { question: 'How is Sloan different from a basic clearing contractor?', answer: 'The work is scoped around the next use of the property. Access, keeper trees, future maintenance, fence lines, trails, drainage, and finish expectations all matter before the machine starts.' },
  { question: 'Can you clear selectively?', answer: 'Yes. Many properties need the brush layer removed while preserving shade, screening, mature trees, and the natural character of the land.' },
  { question: 'Do you offer instant pricing?', answer: 'Yes. The instant pricing calculator gives a fast ballpark for forestry mulching and trail cutting. Final quotes are confirmed after property review.' },
  { question: 'What should I send for a quote?', answer: 'Send the property address or parcel link, photos or video of the worst areas, rough acreage or trail length, and what you want the property to become.' },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: 'Sloan Property Progressions',
  description: 'Selective forestry mulching, trail cutting, fence-line clearing, acreage cleanup, and rural property preparation across Northeast Texas.',
  url: 'https://sloanpropertyprogressions.com',
  email: 'quotes@sloanpropertyprogressions.com',
  areaServed: ['Tyler TX', 'Longview TX', 'Texarkana TX', 'Marshall TX', 'Mount Pleasant TX', 'Sulphur Springs TX', 'East Texas', 'Northeast Texas'],
  priceRange: '$$'
};
---

<Layout title="Sloan Property Progressions | Rural Property Clearing & Forestry Mulching" description="Selective forestry mulching, trail cutting, fence-line clearing, acreage cleanup, and rural property preparation across Northeast Texas." schema={schema}>
  <Header client:load />

  <main class="bg-[#F2EBDF] text-[#1E2A1B] overflow-hidden">
    <section class="relative min-h-[92vh] pt-28 pb-16 md:pt-32 md:pb-24 overflow-hidden">
      <div class="absolute inset-0 netx-topo opacity-35"></div>
      <div class="absolute -right-40 -top-40 h-[34rem] w-[34rem] rounded-full bg-[#F37121]/10 blur-3xl"></div>
      <div class="absolute left-0 bottom-0 h-48 w-full bg-gradient-to-t from-[#F2EBDF] to-transparent"></div>

      <div class="relative container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-[minmax(0,0.92fr)_minmax(420px,0.72fr)] gap-12 lg:gap-16 items-center">
          <div>
            <p class="kicker mb-5">Rural property progression</p>
            <h1 class="font-[Rajdhani] font-bold uppercase leading-[0.88] tracking-tight text-[3.45rem] min-[420px]:text-6xl sm:text-7xl md:text-8xl lg:text-9xl text-[#334D2B]">
              Open The Land.<br />
              <span class="text-[#F37121]">Keep Its Character.</span>
            </h1>
            <p class="mt-7 max-w-2xl text-xl md:text-2xl leading-relaxed text-[#334D2B]/85">
              Selective forestry mulching, trails, fence-line access, and acreage cleanup for landowners who want progress — not a property scraped bare.
            </p>
            <div class="mt-10 flex flex-col sm:flex-row gap-4">
              <a href="/get-a-quote" class="inline-flex items-center justify-center bg-[#334D2B] text-[#F2EBDF] px-8 py-4 font-[Rajdhani] font-bold text-xl uppercase tracking-wide hover:bg-[#1E2A1B] transition">Plan My Property</a>
              <a href="/instant-pricing" class="inline-flex items-center justify-center border-2 border-[#F37121] text-[#334D2B] px-8 py-4 font-[Rajdhani] font-bold text-xl uppercase tracking-wide hover:bg-[#F37121] hover:text-white transition">Instant Pricing</a>
            </div>
          </div>

          <div class="relative">
            <div class="absolute -left-8 -top-8 h-full w-full border-2 border-[#334D2B]/20"></div>
            <div class="relative bg-[#334D2B] p-4 shadow-[0_35px_90px_rgba(30,42,27,0.25)]">
              <img src="/images/sloan/hero-property-progression.jpg" alt="Selectively cleared rural property trail through East Texas woods" class="h-[540px] w-full object-cover" fetchpriority="high" />
              <div class="absolute inset-x-4 bottom-4 bg-[#F2EBDF]/95 p-5 md:p-6 border-l-4 border-[#F37121] shadow-xl">
                <div class="flex items-start gap-4">
                  <img src="/assets/spp-emblem.png" alt="" class="h-14 w-14 object-contain" loading="lazy" />
                  <div>
                    <p class="font-[Rajdhani] text-sm font-bold uppercase tracking-[0.18em] text-[#F37121]">Property note</p>
                    <p class="mt-1 text-lg font-semibold text-[#334D2B] leading-snug">The goal is usable land that still feels like your land.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-24 bg-[#F2EBDF]">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-[0.85fr_1.15fr] gap-10 lg:gap-16 items-start">
          <div class="sticky top-28">
            <p class="kicker mb-3">Three ways land gets stuck</p>
            <h2 class="font-[Rajdhani] uppercase font-bold text-5xl md:text-7xl leading-none text-[#334D2B]">Every Property Has A Next Step.</h2>
            <p class="mt-5 text-lg text-[#334D2B]/75 leading-relaxed">Some land needs access. Some needs a reset. Some needs preparation for what comes next. The right scope starts with the outcome.</p>
          </div>
          <div class="space-y-6">
            {pathways.map((path, index) => (
              <a href={path.href} class="group grid md:grid-cols-[190px_minmax(0,1fr)] gap-0 bg-white border border-[#334D2B]/10 shadow-lg hover:shadow-2xl transition overflow-hidden">
                <div class="relative h-56 md:h-full min-h-[190px] overflow-hidden">
                  <img src={path.image} alt="" class="h-full w-full object-cover transition duration-500 group-hover:scale-105" loading={index === 0 ? 'eager' : 'lazy'} />
                  <div class="absolute inset-0 bg-[#334D2B]/10"></div>
                </div>
                <div class="p-6 md:p-8 flex flex-col justify-center">
                  <p class="font-[Rajdhani] text-sm font-bold uppercase tracking-[0.2em] text-[#F37121]">{path.eyebrow}</p>
                  <h3 class="mt-2 font-[Rajdhani] text-4xl font-bold uppercase text-[#334D2B]">{path.title}</h3>
                  <p class="mt-3 text-[#334D2B]/75 leading-relaxed">{path.copy}</p>
                  <span class="mt-5 font-[Rajdhani] font-bold uppercase tracking-wide text-[#334D2B] group-hover:text-[#F37121]">Explore this path →</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-24 bg-[#334D2B] text-[#F2EBDF] relative overflow-hidden">
      <div class="absolute inset-0 netx-topo opacity-20"></div>
      <div class="relative container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mb-12">
          <p class="kicker mb-3">The Sloan method</p>
          <h2 class="font-[Rajdhani] uppercase font-bold text-5xl md:text-7xl leading-none">Clear With A Plan.</h2>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-px bg-white/15 border border-white/15">
          {planningSteps.map(([num, title, copy]) => (
            <div class="bg-[#334D2B]/95 p-7 min-h-[280px]">
              <div class="font-[Rajdhani] text-5xl font-bold text-[#F37121]">{num}</div>
              <h3 class="mt-8 font-[Rajdhani] text-3xl font-bold uppercase leading-none">{title}</h3>
              <p class="mt-4 text-[#F2EBDF]/75 leading-relaxed">{copy}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 md:py-24 bg-[#F2EBDF]">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-[0.9fr_1.1fr] gap-10 lg:gap-16 items-center">
          <div class="relative order-2 lg:order-1">
            <div class="absolute -right-6 -bottom-6 h-full w-full bg-[#334D2B]"></div>
            <img src="/images/netx/services/fence-line-clearing.jpg" alt="Recovered rural fence line" class="relative h-[520px] w-full object-cover shadow-2xl" loading="lazy" />
          </div>
          <div class="order-1 lg:order-2">
            <p class="kicker mb-3">Before the quote</p>
            <h2 class="font-[Rajdhani] uppercase font-bold text-5xl md:text-7xl leading-none text-[#334D2B]">We Decide What Should Stay.</h2>
            <p class="mt-6 text-lg text-[#334D2B]/75 leading-relaxed">Before clearing starts, the plan should identify what is worth protecting, what needs opened, and how the finished property should function when the work is done.</p>
            <div class="mt-8 grid sm:grid-cols-2 gap-4">
              {['Keeper trees', 'Property lines', 'Trails & access', 'Future maintenance'].map((item) => (
                <div class="border border-[#334D2B]/15 bg-white p-5 font-[Rajdhani] text-2xl font-bold uppercase text-[#334D2B] shadow-sm">{item}</div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-24 bg-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-12">
          <div class="max-w-3xl">
            <p class="kicker mb-3">Services</p>
            <h2 class="font-[Rajdhani] uppercase font-bold text-5xl md:text-7xl leading-none text-[#334D2B]">Practical Work. Planned Finish.</h2>
          </div>
          <a href="/services/forestry-mulching" class="inline-flex items-center justify-center border-2 border-[#334D2B] px-6 py-3 font-[Rajdhani] font-bold uppercase tracking-wide text-[#334D2B] hover:bg-[#334D2B] hover:text-white transition">View services</a>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-px bg-[#334D2B]/15 border border-[#334D2B]/15">
          {services.map((service) => (
            <a href={service.href} class="group bg-white p-7 min-h-[230px] hover:bg-[#F2EBDF] transition">
              <h3 class="font-[Rajdhani] text-3xl font-bold uppercase text-[#334D2B] group-hover:text-[#F37121] transition">{service.title}</h3>
              <p class="mt-4 text-[#334D2B]/70 leading-relaxed">{service.copy}</p>
              <span class="mt-8 inline-block font-[Rajdhani] font-bold uppercase tracking-wide text-[#334D2B]">Learn more →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 md:py-20 bg-[#334D2B] text-white relative overflow-hidden">
      <div class="absolute inset-0 netx-topo opacity-10"></div>
      <div class="absolute -right-24 top-16 h-72 w-72 rounded-full bg-[#F37121]/15 blur-3xl"></div>
      <div class="relative container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-[220px_minmax(0,1fr)_auto] gap-8 lg:gap-12 items-center border border-white/10 bg-white/[0.035] p-6 md:p-8 shadow-[0_30px_90px_rgba(0,0,0,0.35)]">
          <img src="/images/netx/certified/brushworks-certified.png" alt="Brushworks Certified Process Operator badge" class="mx-auto w-full max-w-[190px] drop-shadow-2xl" loading="lazy" />
          <div>
            <p class="kicker mb-3">Certified Process Operator</p>
            <h2 class="font-[Rajdhani] uppercase font-bold text-4xl md:text-5xl leading-none">Backed By The Brushworks Standard.</h2>
            <p class="mt-4 text-lg text-zinc-300 leading-relaxed max-w-3xl">Independent local operator. Reviewed for equipment fit, clear scope, communication, and the ability to deliver cleaner land-clearing outcomes.</p>
            <div class="mt-5 flex flex-wrap gap-3 text-sm font-semibold text-zinc-300">
              <span class="border border-white/10 bg-black/25 px-3 py-2">Clear scope</span>
              <span class="border border-white/10 bg-black/25 px-3 py-2">Vetted equipment</span>
              <span class="border border-white/10 bg-black/25 px-3 py-2">Professional communication</span>
              <span class="border border-white/10 bg-black/25 px-3 py-2">Operator support</span>
            </div>
          </div>
          <div class="flex flex-col gap-3 lg:min-w-[240px]">
            <a href="https://www.brushworksco.com/certified-operators/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center bg-[#F37121] text-white px-6 py-4 font-[Rajdhani] font-bold text-lg uppercase tracking-wide hover:bg-[#ff8436] transition">What Certified Means</a>
            <a href="/get-a-quote" class="inline-flex items-center justify-center border-2 border-white/70 text-white px-6 py-4 font-[Rajdhani] font-bold text-lg uppercase tracking-wide hover:bg-white hover:text-[#334D2B] transition">Get A Quote</a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-24 bg-[#F2EBDF]">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mb-12">
          <p class="kicker mb-3">Field notes</p>
          <h2 class="font-[Rajdhani] uppercase font-bold text-5xl md:text-7xl leading-none text-[#334D2B]">Proof, Presented Differently.</h2>
          <p class="mt-5 text-lg text-[#334D2B]/75">A good clearing project is not just before and after. It is what changed, why it mattered, and how the land can be maintained afterward.</p>
        </div>
        <div class="grid lg:grid-cols-3 gap-6">
          {fieldNotes.map((note) => (
            <article class="bg-white border border-[#334D2B]/10 shadow-lg overflow-hidden">
              <img src={note.image} alt="" class="h-64 w-full object-cover" loading="lazy" />
              <div class="p-6">
                <h3 class="font-[Rajdhani] text-3xl font-bold uppercase leading-none text-[#334D2B]">{note.title}</h3>
                <p class="mt-4 text-[#334D2B]/70 leading-relaxed">{note.copy}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 md:py-24 bg-[#1E2A1B] text-[#F2EBDF]">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-[0.85fr_1.15fr] gap-10 lg:gap-14 items-start">
          <div>
            <p class="kicker mb-3">Video library</p>
            <h2 class="font-[Rajdhani] uppercase font-bold text-5xl md:text-7xl leading-none">Watch The Thinking, Not Just The Machine.</h2>
            <p class="mt-5 text-[#F2EBDF]/70 text-lg leading-relaxed">Short field videos and process notes help landowners understand how a professional clearing project is scoped, priced, and finished.</p>
          </div>
          <div class="grid gap-5">
            {videoNotes.map((video) => (
              <button class="youtube-lite group grid md:grid-cols-[220px_minmax(0,1fr)] gap-0 overflow-hidden border border-white/10 bg-white/[0.04] text-left hover:bg-white/[0.07] transition" data-youtube-id={video.id} aria-label={`Play ${video.title}`}>
                <div class="relative h-48 md:h-full min-h-[150px] bg-[#334D2B]">
                  <img src={`https://i.ytimg.com/vi/${video.id}/hqdefault.jpg`} alt="" class="h-full w-full object-cover opacity-80 group-hover:opacity-100 transition" loading="lazy" />
                  <div class="absolute inset-0 flex items-center justify-center"><span class="flex h-16 w-16 items-center justify-center rounded-full bg-[#F37121] text-2xl text-white shadow-xl">▶</span></div>
                </div>
                <div class="p-6 md:p-8">
                  <p class="font-[Rajdhani] text-sm font-bold uppercase tracking-[0.18em] text-[#F37121]">Field video</p>
                  <h3 class="mt-2 font-[Rajdhani] text-3xl font-bold uppercase leading-none text-white">{video.title}</h3>
                  <p class="mt-4 text-[#F2EBDF]/70 leading-relaxed">{video.copy}</p>
                </div>
              </button>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-24 bg-white">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-start">
          <div>
            <p class="kicker mb-3">Questions</p>
            <h2 class="font-[Rajdhani] uppercase font-bold text-5xl md:text-7xl leading-none text-[#334D2B]">What Landowners Ask First.</h2>
          </div>
          <FAQ items={faqItems} client:load />
        </div>
      </div>
    </section>

    <section class="py-16 md:py-24 bg-[#F37121] text-white relative overflow-hidden">
      <div class="absolute inset-0 netx-grid-dark opacity-20"></div>
      <div class="relative container mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <p class="font-[Rajdhani] text-sm font-bold uppercase tracking-[0.22em] text-white/80 mb-4">Start with the next step</p>
        <h2 class="font-[Rajdhani] uppercase font-bold text-5xl md:text-8xl leading-none max-w-4xl mx-auto">Tell Us What The Property Needs To Become.</h2>
        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/get-a-quote" class="inline-flex items-center justify-center bg-[#334D2B] text-white px-8 py-4 font-[Rajdhani] font-bold text-xl uppercase tracking-wide hover:bg-[#1E2A1B] transition">Get a Quote</a>
          <a href="/instant-pricing" class="inline-flex items-center justify-center bg-white text-[#334D2B] px-8 py-4 font-[Rajdhani] font-bold text-xl uppercase tracking-wide hover:bg-[#F2EBDF] transition">Try Instant Pricing</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script>
    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      const button = target.closest('.youtube-lite');
      if (!(button instanceof HTMLElement)) return;
      const id = button.getAttribute('data-youtube-id');
      if (!id) return;
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube.com/embed/${id}?autoplay=1&rel=0`;
      iframe.title = button.getAttribute('aria-label') || 'Land clearing field video';
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      iframe.allowFullscreen = true;
      iframe.className = 'h-full min-h-[260px] w-full';
      button.replaceWith(iframe);
    });
  </script>
</Layout>
