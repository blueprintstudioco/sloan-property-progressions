---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header';
import Footer from '../components/Footer.astro';
---

<Layout title="Get a Quote | Sloan Property Progressions" description="Request a Northeast Texas land clearing, forestry mulching, trail clearing, fence-line clearing, or acreage cleanup quote.">
  <Header client:load />
  <main class="pt-20 bg-[#F2EBDF] text-[#334D2B]">
    <section class="page-hero py-20 md:py-28">
      <div class="container mx-auto px-6 max-w-4xl">
        <p class="kicker mb-4">Free property review</p>
        <h1 class="font-heading font-semibold text-5xl md:text-7xl leading-none mb-6">Tell Us What Needs Cleared.</h1>
        <p class="text-xl text-white/75 leading-relaxed">Send the parcel address, photos or video, approximate acreage or footage, access notes, and what you want the land to look like when the work is finished.</p>
      </div>
    </section>

    <section class="py-16 md:py-24">
      <div class="container mx-auto px-6 grid lg:grid-cols-[0.9fr_1.1fr] gap-10">
        <aside class="card-dark p-8 text-white h-fit">
          <img src="/assets/spp-logo.png" alt="Sloan Property Progressions" class="h-24 w-auto mb-6" />
          <h2 class="font-heading font-semibold text-3xl mb-4">Fast Quote Checklist</h2>
          <ul class="space-y-3 text-zinc-300">
            <li>• Property address or parcel link</li>
            <li>• Photos/video of the brush and access</li>
            <li>• Approximate acreage or linear footage</li>
            <li>• What stays, what goes, and desired finish</li>
            <li>• Gates, wet areas, utilities, fences, or slope issues</li>
          </ul>
          <div class="mt-8 border-t border-white/10 pt-6">
            <p class="font-heading tracking-[0.18em] text-[#F37121] font-bold text-sm mb-2">Typical work</p>
            <p class="text-zinc-300">Forestry mulching, brush clearing, fence lines, trails, acreage cleanup, and land prep.</p>
          </div>
        </aside>

        <div class="bg-white border border-black/10 shadow-xl p-8 md:p-10">
          <h2 class="font-heading font-semibold text-4xl mb-4">Request A Land Clearing Quote</h2>
          <p class="text-zinc-700 mb-8">Use the service links below if you know exactly what you need. If not, start with land clearing and include photos — we can help identify the right scope.</p>
          <div class="grid sm:grid-cols-2 gap-4">
            {[
              ['Forestry Mulching','/services/forestry-mulching'],
              ['Land Clearing','/services/land-clearing'],
              ['Fence Lines','/services/fence-line-clearing'],
              ['Trail Clearing','/services/trail-clearing'],
              ['Acreage Cleanup','/services/acreage-cleanup'],
              ['Site Preparation','/services/site-preparation'],
            ].map(([item, href]) => (
              <a href={href} class="border border-black/10 p-5 hover:border-[#F37121] hover:text-[#F37121] transition font-semibold">{item} →</a>
            ))}
          </div>
          <div class="mt-8 p-6 bg-[#334D2B] text-white">
            <p class="font-heading tracking-[0.2em] text-[#F37121] font-bold text-sm mb-2">Want the fastest answer?</p>
            <p class="text-zinc-300">Send the address, photos, and what you want cleared. The more clearly we can see access, density, and finish expectations, the faster we can scope it.</p>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
